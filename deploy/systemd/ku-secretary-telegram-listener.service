[Unit]
Description=KU Secretary Telegram listener
Wants=network-online.target
After=network-online.target

[Service]
Type=simple
WorkingDirectory=%h/KUSecretary
EnvironmentFile=%h/KUSecretary/.env
ExecStart=/path/to/KU_Secretary/.venv/bin/kus telegram-listener
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target
