# Required for P0
STORAGE_ROOT_DIR=/path/to/KUSecretary
TIMEZONE=Asia/Seoul

# ── Korea University connectors (via vendored ku-portal-mcp) ──────────
# These drive the new ku_portal_auth, ku_timetable, ku_courses, ku_lms,
# and ku_library connectors. Both vars are required for any
# authenticated KUPID/Canvas operation.
#
# IMPORTANT: KSSO accounts with OTP enabled cannot complete the Canvas
# SAML flow — disable OTP on the KU SSO portal before using LMS features,
# or fall back to read-only public endpoints (ku_library only).
KU_PORTAL_ID=
KU_PORTAL_PW=

# Opt-in: replace the playwright/storage_state KUPID timetable scraping with
# the new KUPID SSO + httpx adapter (vendored ku-portal-mcp). Default off so
# existing sync flow + tests are unchanged. Set to true once you have
# KU_PORTAL_ID/PW filled in and KSSO OTP disabled.
KUPID_SSO_TIMETABLE_ENABLED=false

# ── Legacy / fallback (Moodle UClass) ─────────────────────────────────
# Korea University's main LMS is Canvas (mylms.korea.ac.kr), reached
# through ku_lms. The UCLASS_* variables below are kept as a
# Moodle-compat fallback for schools/instances still on a Moodle LMS.
# Leave blank when using Canvas via ku_lms.
UCLASS_WS_BASE=
UCLASS_WSTOKEN=
UCLASS_USERNAME=
UCLASS_PASSWORD=
UCLASS_TOKEN_SERVICE=moodle_mobile_app
UCLASS_TOKEN_ENDPOINT=

# Optional KU OpenAPI timetable (separate from KUPID scraping in
# ku_timetable). Leave blank to use the scraping connector exclusively.
KU_OPENAPI_TIMETABLE_URL=
KU_OPENAPI_TIMETABLE_API_KEY=
KU_OPENAPI_TIMETABLE_TIMEOUT_SEC=15
KU_OPENAPI_YEAR=
KU_OPENAPI_TERM=

# Optional
DATABASE_PATH=data/ku.db

# UClass wsfunction overrides
UCLASS_FUNC_SITE_INFO=core_webservice_get_site_info
UCLASS_FUNC_POPUP_NOTIFICATIONS=message_popup_get_popup_notifications
UCLASS_FUNC_ACTION_EVENTS=core_calendar_get_action_events_by_timesort
UCLASS_FUNC_COURSES=core_enrol_get_users_courses
UCLASS_FUNC_COURSE_CONTENTS=core_course_get_contents
UCLASS_FUNC_ASSIGNMENTS=mod_assign_get_assignments
UCLASS_FUNC_FORUMS=mod_forum_get_forums_by_courses
UCLASS_FUNC_FORUM_DISCUSSIONS=mod_forum_get_forum_discussions_paginated

# Optional UClass feature flags
UCLASS_ENABLE_POPUP_NOTIFICATIONS=true
UCLASS_ENABLE_ACTION_EVENTS=true
UCLASS_ENABLE_COURSES=true
UCLASS_ENABLE_CONTENTS=true
UCLASS_ENABLE_ASSIGNMENTS=true
UCLASS_ENABLE_FORUMS=false
UCLASS_REQUIRED_WSFUNCTIONS=
UCLASS_DOWNLOAD_MATERIALS=true
UCLASS_DOWNLOAD_RETRIES=3
UCLASS_DOWNLOAD_BACKOFF_SEC=1.5

# Optional portal import namespace
PORTAL_SLUG=academic

# Optional Telegram inbox
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_POLL_LIMIT=100
TELEGRAM_COMMANDS_ENABLED=false
TELEGRAM_SMART_COMMANDS_ENABLED=false
TELEGRAM_ASSISTANT_ENABLED=false
TELEGRAM_ASSISTANT_WRITE_ENABLED=false
ONBOARDING_PUBLIC_BASE_URL=
ONBOARDING_SESSION_TTL_MINUTES=15

# Optional LLM summaries
LLM_ENABLED=false
LLM_PROVIDER=local
LLM_MODEL=gemma4
LLM_LOCAL_ENDPOINT=http://127.0.0.1:11434/api/chat
LLM_TIMEOUT_SEC=30

# Optional remote ops dashboard opener for the operator Mac
OPS_DASHBOARD_SSH_HOST=
OPS_DASHBOARD_SSH_USER=
OPS_DASHBOARD_SSH_PORT=22
OPS_DASHBOARD_REMOTE_HOST=127.0.0.1
OPS_DASHBOARD_REMOTE_PORT=8793
OPS_DASHBOARD_LOCAL_PORT=8793
OPS_DASHBOARD_URL_PATH=/

# Optional outbound privacy gate
INCLUDE_IDENTITY=false

# Optional material extraction + briefing
MATERIAL_EXTRACTION_ENABLED=false
MATERIAL_BRIEFING_ENABLED=false
MATERIAL_BRIEF_PUSH_ENABLED=false
MATERIAL_BRIEF_PUSH_MAX_ITEMS=3
MATERIAL_EXTRACT_MAX_CHARS=12000

# Optional study review scheduler
REVIEW_ENABLED=false
REVIEW_INTERVALS_DAYS=1,3,7,14
REVIEW_DURATION_MIN=25
REVIEW_MORNING_HOUR=9

# Optional daily digest push
DIGEST_ENABLED=false
DIGEST_TIME_LOCAL=08:30
DIGEST_CHANNEL=telegram
DIGEST_TASK_LOOKAHEAD_DAYS=3

# Optional morning/evening briefing push
BRIEFING_ENABLED=false
BRIEFING_MORNING_TIME_LOCAL=07:30
BRIEFING_EVENING_TIME_LOCAL=21:00
BRIEFING_CHANNEL=telegram
BRIEFING_DELIVERY_MODE=direct
BRIEFING_RELAY_ENDPOINT=
BRIEFING_RELAY_SHARED_SECRET=
BRIEFING_RELAY_STATE_FILE=data/briefing_relay_state.json
BRIEFING_TASK_LOOKAHEAD_DAYS=7
BRIEFING_MAX_CLASSES=6
